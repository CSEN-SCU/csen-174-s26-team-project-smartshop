# Copy to .env and fill in for live AI list cleanup.
# Never commit .env to the repo.
# If OPENAI_API_KEY is empty, the app uses a simple offline parser (demo still works).

# OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: custom API base (OpenAI-compatible)
# OPENAI_BASE_URL=https://api.openai.com/v1
